{
  "{{chrome}}.manifest_version": 3,
  "{{firefox}}.manifest_version": 2,
  "name": "Batchcamp",
  "description": "Bulk downloader for your Bandcamp purchases",
  "version": "2.0.0",
  "{{chrome}}.action": {
    "default_title": "Open batchcamp",
    "default_icon": {
      "16": "icon-16.png",
      "64": "icon-64.png",
      "128": "icon-128.png"
    }
  },
  "{{firefox}}.browser_action": {
    "default_title": "Open batchcamp",
    "default_icon": {
      "16": "icon-16.png",
      "64": "icon-64.png",
      "128": "icon-128.png"
    }
  },
  "content_scripts": [
    {
      "js": ["src/content/index.ts"],
      "matches": ["https://bandcamp.com/*", "https://*.bandcamp.com/*"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "{{chrome}}.service_worker": "src/background/index.ts",
    "{{firefox}}.scripts": ["src/background/index.ts"]
  },
  "{{chrome}}.permissions": ["storage", "downloads", "downloads.ui"],
  "{{chrome}}.host_permissions": [
    "https://*.bandcamp.com/*",
    "https://*.bcbits.com/*"
  ],
  "{{firefox}}.permissions": [
    "storage",
    "downloads",
    "cookies",
    "https://bandcamp.com/*",
    "https://*.bandcamp.com/*",
    "https://*.bcbits.com/*"
  ],
  "{{firefox}}.browser_specific_settings": {
    "gecko": {
      "id": "{d44fa1f9-1400-401d-a79e-650d466ec6d6}"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "64": "icon-64.png",
    "128": "icon-128.png"
  }
}
